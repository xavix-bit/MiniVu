{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniVu",
  "version": "0.1.0",
  "identifier": "com.asleak.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "quick-panel",
        "title": "MiniVu",
        "width": 480,
        "height": 680,
        "resizable": true,
        "minWidth": 400,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false
      },
      {
        "label": "main",
        "title": "MiniVu · 设置",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
